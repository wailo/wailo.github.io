{
  "name": "v3_personal_page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "wasmTag": "v0.1.12",
  "scripts": {
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "format": "prettier .  --write",
    "docker:up": "docker compose up -d",
    "check": "vue-tsc -b",
    "docker:down": "docker compose down || true",
    "dev": "npm run dev:modelfile && npm run docker:up && 'npm run docker:down' EXIT; vite",
    "preinstall": "tsx scripts/fetch-wasm-binary.ts && npm run generate-modelfile",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -b master",
    "generate-modelfile": "tsx src/generate-modelfile.ts",
    "dev:modelfile": "tsx src/generate-modelfile.ts && ollama create flightsimModel -f src/wasm/generated/Modelfile",
    "prepare": "husky install"
  },
  "dependencies": {
    "cesium": "^1.141.0",
    "fuse.js": "^7.1.0",
    "marked": "^15.0.11",
    "monaco-editor-vue3": "^1.0.5",
    "olcs": "^2.23.0",
    "peerjs": "^1.5.4",
    "pocketbase": "^0.26.1",
    "ts-morph": "^27.0.2",
    "uplot": "^1.6.32",
    "vite-plugin-cesium": "^1.2.23",
    "vue": "^3.5.28",
    "vue-qr": "^4.0.9",
    "vue-router": "^4.5.0",
    "vue-whiteboard-composable": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.4.39",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^6.3.5",
    "vite-plugin-checker": "^0.9.3",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^2.0.21"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --cache --fix",
    "*.--write": "prettier --write"
  }
}
