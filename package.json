{
  "name": "v3_personal_page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "docker:up": "docker compose up -d",
    "check": "vue-tsc -b",
    "docker:down": "docker compose down || true",
    "dev": "npm run dev:modelfile && npm run docker:up && 'npm run docker:down' EXIT; vite",
    "build": "npm run build:emscripten && vue-tsc -b && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -b master",
    "copy:emscripten":"src=node_modules/Compact-Flight-Simulator/build_wasm_5.0.1/bin && cp -a \"$src\"/flightsimulator_exec.{data,wasm} ~/sandbox/vue/flight_simulator_app/public/ && cp -a \"$src\"/flightsimulator_exec*{js,d.ts,meta.ts} ~/sandbox/vue/flight_simulator_app/src/wasm/",
    "build:emscripten": "git -C node_modules/Compact-Flight-Simulator checkout a95c20b && ./node_modules/Compact-Flight-Simulator/build_wasm.sh && npm run copy:emscripten",
    "preinstall": "[ -z \"$ACCESS_TOKEN\" ] && set -a && . .env && set +a; git clone https://oauth2:$ACCESS_TOKEN@github.com/wailo/Compact-Flight-Simulator.git node_modules/Compact-Flight-Simulator",
    "generate-modelfile": "node dist/generate-modelfile.js",
    "dev:modelfile": "tsx src/generate-modelfile.ts && ollama create flightsimModel -f Modelfile"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "marked": "^15.0.11",
    "monaco-editor-vue3": "^1.0.5",
    "peerjs": "^1.5.4",
    "pocketbase": "^0.26.1",
    "ts-morph": "^27.0.2",
    "uplot": "^1.6.32",
    "vue": "^3.5.28",
    "vue-qr": "^4.0.9",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.39",
    "prettier": "3.3.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^6.3.5",
    "vite-plugin-checker": "^0.9.3",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^2.0.21"
  }
}
